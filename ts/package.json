{
  "name": "@foresthub/ts",
  "private": true,
  "description": "TypeScript workspace for the ForestHub open platform (workflow-core, workflow-builder).",
  "workspaces": [
    "workflow-core",
    "workflow-builder",
    "app"
  ],
  "scripts": {
    "generate": "npm run generate --workspace @foresthub/workflow-core",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "tsc -b workflow-core workflow-builder"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4"
  }
}
