{
  "name": "@foresthub/workflow-core",
  "version": "0.1.0",
  "description": "Headless workflow types + serialization + pure validator. No React, no browser.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types/node/*": {
      "types": "./dist/types/node/*.d.ts",
      "import": "./dist/types/node/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*/index.d.ts",
      "import": "./dist/types/*/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "generate": "openapi-typescript ../../contract/workflow.yaml -o src/api/workflow.ts",
    "build": "tsc -b",
    "test": "node --test"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.6.0"
  }
}
