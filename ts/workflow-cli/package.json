{
  "name": "@foresthubai/workflow-cli",
  "version": "0.5.2",
  "type": "module",
  "description": "fh-workflow CLI — author, validate, and visually edit Edge Agents workflow JSON. Bundles the visual builder; no other install required.",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "fh-workflow": "dist-cli/cli.js"
  },
  "files": [
    "dist",
    "dist-cli",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "generate": "openapi-typescript ../../contract/deployment.yaml -o cli/deploy/api/deployment.ts && openapi-typescript ../../contract/engine.yaml -o cli/deploy/api/engine.ts && openapi-typescript ../../contract/camera.yaml -o cli/deploy/api/camera.ts && openapi-typescript ../../contract/ml.yaml -o cli/deploy/api/ml.ts",
    "build": "vite build",
    "build:cli": "node ./scripts/build-cli.mjs",
    "build:all": "npm run build && npm run build:cli",
    "preview": "vite preview",
    "cli": "node ./cli/fh-workflow.mjs",
    "open": "node ./cli/fh-workflow.mjs open",
    "check-schema": "node ./cli/fh-workflow.mjs check-schema",
    "validate": "node ./cli/fh-workflow.mjs validate",
    "deploy": "node ./cli/fh-workflow.mjs deploy",
    "test": "vitest run",
    "prepublishOnly": "npm run build:all"
  },
  "devDependencies": {
    "@foresthubai/workflow-builder": "*",
    "@foresthubai/workflow-core": "*",
    "@inquirer/prompts": "^8.5.0",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.28.0",
    "i18next": "^25.3.2",
    "js-yaml": "^4.2.0",
    "lucide-react": "^0.462.0",
    "openapi-typescript": "^7.4.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^15.6.1",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.3",
    "zod": "^4.4.3"
  }
}
