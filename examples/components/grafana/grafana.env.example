# Device-local env for the "grafana" component.
#
# Copy to grafana.env next to docker-compose.yml, fill in, and NEVER commit it.
# The renderer attaches it to the grafana service as an optional env_file, so a
# component with no secrets can simply have no file.
#
# Secrets live HERE, never in the deployment spec. Non-secret settings go in the
# spec's `config` instead (see component.json). To change a secret: edit this
# file, then `docker compose up -d` (recreate; a plain `restart` keeps the old
# values).
#
# Note: Grafana reads GF_* env vars natively. The wrapper sets the non-secret
# GF_* from `config`; this file supplies the secret ones the same way.

# Admin password Grafana sets on first boot. Secret.
GF_SECURITY_ADMIN_PASSWORD=change-me
