# Env template for the "grafana" component. The wizard reads it to generate
# grafana.env in the bundle: filled values become defaults (taken silently),
# empty ones are prompted at a terminal (left blank otherwise). Grafana reads
# every GF_* var natively, so this one file carries all of its configuration.
#
# Leave secrets empty here (this file is committable); fill non-secret tunables.

# Admin password set on first boot. Secret — leave empty, fill in grafana.env.
GF_SECURITY_ADMIN_PASSWORD=

# Non-secret tunables, taken as-is.
GF_SECURITY_ADMIN_USER=admin
GF_USERS_ALLOW_SIGN_UP=false
GF_ANALYTICS_REPORTING_ENABLED=false
GF_ANALYTICS_CHECK_FOR_UPDATES=false
